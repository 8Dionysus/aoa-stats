{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/component-refresh-summary.schema.json",
  "title": "aoa-stats component refresh summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "owner_repo_counts",
    "status_counts",
    "drift_class_counts",
    "components"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_component_refresh_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "owner_repo_counts": {
      "$ref": "#/$defs/string_count_map"
    },
    "status_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "refresh_recommended",
        "refresh_active",
        "current",
        "deferred",
        "recovered"
      ],
      "properties": {
        "refresh_recommended": {
          "type": "integer",
          "minimum": 0
        },
        "refresh_active": {
          "type": "integer",
          "minimum": 0
        },
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "deferred": {
          "type": "integer",
          "minimum": 0
        },
        "recovered": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "drift_class_counts": {
      "$ref": "#/$defs/string_count_map"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component_ref",
          "owner_repo",
          "latest_decision_status",
          "current_status",
          "latest_route_class",
          "latest_observed_at"
        ],
        "properties": {
          "component_ref": {
            "type": "string",
            "minLength": 1
          },
          "owner_repo": {
            "type": "string",
            "minLength": 1
          },
          "latest_decision_status": {
            "enum": [
              "chosen",
              "deferred",
              "safe_stop",
              "unreviewed"
            ]
          },
          "current_status": {
            "enum": [
              "refresh_recommended",
              "refresh_active",
              "current",
              "deferred",
              "recovered"
            ]
          },
          "latest_route_class": {
            "enum": [
              "observe",
              "revalidate",
              "rebuild",
              "reexport",
              "regenerate",
              "reproject",
              "repair",
              "defer"
            ]
          },
          "latest_observed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      }
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "string_count_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
