{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/continuity-window-summary.schema.json",
  "title": "aoa-stats continuity window summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "continuity_ref",
    "current_status",
    "open_revision_windows",
    "successful_reanchors",
    "failed_reanchors",
    "last_anchor_artifact_ref",
    "drift_flags",
    "bounded_revision_count"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_continuity_window_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "continuity_ref": {
      "type": "string",
      "minLength": 1
    },
    "current_status": {
      "type": "string",
      "enum": [
        "active",
        "reanchor_needed",
        "reanchored",
        "closed"
      ]
    },
    "open_revision_windows": {
      "type": "integer",
      "minimum": 0
    },
    "successful_reanchors": {
      "type": "integer",
      "minimum": 0
    },
    "failed_reanchors": {
      "type": "integer",
      "minimum": 0
    },
    "last_anchor_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "drift_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "bounded_revision_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
