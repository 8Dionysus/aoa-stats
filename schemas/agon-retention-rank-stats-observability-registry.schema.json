{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agon retention rank stats observability registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "registry_id": {
      "const": "agon.stats.retention_rank_observability.registry.v1"
    },
    "wave": {
      "const": "XIV"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "live_protocol": {
      "const": false
    },
    "runtime_effect": {
      "enum": [
        "candidate_only",
        "none",
        "review_surface_only",
        "local_dry_run_candidate_only"
      ]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "stop_lines": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "source_config": {
      "const": "config/agon_retention_rank_stats_observability.seed.json"
    },
    "entry_count": {
      "type": "integer",
      "minimum": 1
    },
    "generated_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "registry_id",
    "wave",
    "status",
    "live_protocol",
    "runtime_effect",
    "entry_count",
    "entries",
    "stop_lines",
    "source_config",
    "generated_note"
  ],
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "candidate_only": {
          "const": true
        },
        "live_authority": {
          "const": false
        },
        "allowed_effect": {
          "type": "string",
          "minLength": 1
        },
        "forbidden_effects": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "assistant_rank_mode": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "$ref": "#/$defs/stringArray"
        },
        "eligible_jurisdiction_candidates": {
          "$ref": "#/$defs/stringArray"
        },
        "forbidden_jurisdictions_without_future_review": {
          "$ref": "#/$defs/stringArray"
        },
        "handoffs": {
          "$ref": "#/$defs/stringArray"
        },
        "inputs": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        },
        "offices": {
          "$ref": "#/$defs/stringArray"
        },
        "outputs": {
          "$ref": "#/$defs/stringArray"
        },
        "review_required": {
          "type": "boolean"
        },
        "standing_floor": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "kind",
        "owner",
        "status",
        "description",
        "candidate_only",
        "live_authority",
        "allowed_effect",
        "forbidden_effects"
      ]
    }
  }
}
