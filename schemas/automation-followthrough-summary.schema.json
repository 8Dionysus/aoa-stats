{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/automation-followthrough-summary.schema.json",
  "title": "aoa-stats automation followthrough summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "window_ref",
    "automation_candidate_count",
    "seed_ready_count",
    "not_now_count",
    "checkpoint_required_count",
    "playbook_seed_candidate_count",
    "real_run_reviewed_count",
    "defer_count",
    "blocker_aggregates"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_automation_followthrough_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "window_ref": {
      "type": "string",
      "minLength": 1
    },
    "automation_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "seed_ready_count": {
      "type": "integer",
      "minimum": 0
    },
    "not_now_count": {
      "type": "integer",
      "minimum": 0
    },
    "checkpoint_required_count": {
      "type": "integer",
      "minimum": 0
    },
    "playbook_seed_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "real_run_reviewed_count": {
      "type": "integer",
      "minimum": 0
    },
    "defer_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocker_aggregates": {
      "$ref": "#/$defs/string_count_map"
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "string_count_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
