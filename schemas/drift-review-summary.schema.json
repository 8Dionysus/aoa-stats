{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/drift-review-summary.schema.json",
  "title": "aoa-stats drift review summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "campaign_ref",
    "review_ref",
    "review_status",
    "review_windows_total",
    "signals_seen",
    "decision_counts",
    "rollback_ref",
    "rollback_ready",
    "source_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_drift_review_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "campaign_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "enum": [
        "review_required",
        "accepted",
        "reanchor",
        "rollback_considered",
        "closed"
      ]
    },
    "review_windows_total": {
      "type": "integer",
      "minimum": 0
    },
    "signals_seen": {
      "$ref": "#/$defs/string_count_map"
    },
    "decision_counts": {
      "$ref": "#/$defs/string_count_map"
    },
    "rollback_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_ready": {
      "type": "boolean"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "string_count_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
