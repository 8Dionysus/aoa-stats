{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Memory Metrics",
  "type": "object",
  "required": [
    "version",
    "metrics",
    "authority"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority": {
      "type": "string"
    }
  }
}
