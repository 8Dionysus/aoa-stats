{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/fork-calibration-summary.schema.json",
  "title": "aoa-stats fork calibration summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_fork_calibration_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "route_ref",
          "decision_count",
          "chosen_branch_counts",
          "max_option_count",
          "realized_outcome_link_count",
          "evidence_ref_count",
          "latest_observed_at"
        ],
        "properties": {
          "route_ref": {
            "type": "string",
            "minLength": 1
          },
          "decision_count": {
            "type": "integer",
            "minimum": 1
          },
          "chosen_branch_counts": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "max_option_count": {
            "type": "integer",
            "minimum": 0
          },
          "realized_outcome_link_count": {
            "type": "integer",
            "minimum": 0
          },
          "evidence_ref_count": {
            "type": "integer",
            "minimum": 0
          },
          "latest_observed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

