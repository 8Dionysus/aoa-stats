{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/summary-surface-catalog.schema.json",
  "title": "aoa-stats summary surface catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "artifact_identity",
    "surface_strength_model_ref",
    "generated_from",
    "validation_refs",
    "deferred_contract_surfaces",
    "surfaces"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_summary_surface_catalog_v2"
    },
    "schema_ref": {
      "const": "schemas/summary-surface-catalog.schema.json"
    },
    "owner_repo": {
      "const": "aoa-stats"
    },
    "surface_kind": {
      "const": "runtime_surface"
    },
    "authority_ref": {
      "const": "docs/ARCHITECTURE.md"
    },
    "artifact_identity": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "surface_strength_model_ref": {
      "const": "stats/surface-catalog/SURFACE_STRENGTH_MODEL.md"
    },
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "validation_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "scripts/build_views.py",
          "scripts/validate_repo.py",
          "tests/test_summary_surface_catalog.py"
        ]
      }
    },
    "deferred_contract_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "contract_ref",
          "schema_ref",
          "input_posture",
          "owner_truth_inputs",
          "activation_condition",
          "activation_gaps",
          "authority_ceiling",
          "consumer_risk"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "contract_only"
          },
          "contract_ref": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "input_posture": {
            "type": "string",
            "minLength": 1
          },
          "owner_truth_inputs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "activation_condition": {
            "type": "string",
            "minLength": 1
          },
          "activation_gaps": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "authority_ceiling": {
            "type": "string",
            "minLength": 1
          },
          "consumer_risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "surface_ref",
          "schema_ref",
          "primary_question",
          "derivation_rule",
          "input_posture",
          "owner_truth_inputs",
          "authority_ceiling",
          "consumer_risk",
          "live_state_capable"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "primary_question": {
            "type": "string",
            "minLength": 1
          },
          "derivation_rule": {
            "type": "string",
            "minLength": 1
          },
          "input_posture": {
            "type": "string",
            "minLength": 1
          },
          "owner_truth_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "authority_ceiling": {
            "type": "string",
            "minLength": 1
          },
          "consumer_risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "live_state_capable": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_class",
        "surface_state",
        "owner_repo",
        "authority_ref",
        "producer",
        "consumer_expectation",
        "privacy_boundary",
        "content_identity",
        "abi_epoch",
        "contract_version",
        "trust_layer",
        "verification",
        "action"
      ],
      "properties": {
        "artifact_class": {
          "const": "derived_observability_readmodel_catalog"
        },
        "surface_state": {
          "const": "public_generated_summary_surface_catalog"
        },
        "owner_repo": {
          "const": "aoa-stats"
        },
        "authority_ref": {
          "const": "docs/ARCHITECTURE.md"
        },
        "producer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "consumer_expectation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "privacy_boundary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content_identity": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "abi_epoch": {
          "const": "aoa_stats_summary_surface_catalog_v2"
        },
        "contract_version": {
          "const": "summary-surface-catalog.schema.json@aoa_stats_summary_surface_catalog_v2#artifact_identity"
        },
        "trust_layer": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "prefixItems": [
            {
              "const": "abi_contract_signature"
            },
            {
              "const": "w3c_prov_lineage"
            }
          ]
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "action": {
          "const": "ADD_CONSUMER_EXPECTATION"
        }
      }
    }
  }
}
