{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/summary-surface-catalog.schema.json",
  "title": "aoa-stats summary surface catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_ref",
    "owner_repo",
    "surface_kind",
    "authority_ref",
    "surface_strength_model_ref",
    "generated_from",
    "validation_refs",
    "deferred_contract_surfaces",
    "surfaces"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_summary_surface_catalog_v2"
    },
    "schema_ref": {
      "const": "schemas/summary-surface-catalog.schema.json"
    },
    "owner_repo": {
      "const": "aoa-stats"
    },
    "surface_kind": {
      "const": "runtime_surface"
    },
    "authority_ref": {
      "const": "docs/ARCHITECTURE.md"
    },
    "surface_strength_model_ref": {
      "const": "docs/SURFACE_STRENGTH_MODEL.md"
    },
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "validation_refs": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "scripts/build_views.py",
          "scripts/validate_repo.py",
          "tests/test_summary_surface_catalog.py"
        ]
      }
    },
    "deferred_contract_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "contract_ref",
          "schema_ref",
          "activation_condition",
          "authority_ceiling"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "contract_only"
          },
          "contract_ref": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "activation_condition": {
            "type": "string",
            "minLength": 1
          },
          "authority_ceiling": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "surface_ref",
          "schema_ref",
          "primary_question",
          "derivation_rule",
          "input_posture",
          "owner_truth_inputs",
          "authority_ceiling",
          "consumer_risk",
          "live_state_capable"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "surface_ref": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "primary_question": {
            "type": "string",
            "minLength": 1
          },
          "derivation_rule": {
            "type": "string",
            "minLength": 1
          },
          "input_posture": {
            "type": "string",
            "minLength": 1
          },
          "owner_truth_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "authority_ceiling": {
            "type": "string",
            "minLength": 1
          },
          "consumer_risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "live_state_capable": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
