{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/source-coverage-summary.schema.json",
  "title": "aoa-stats source coverage summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "source_mode",
    "input_registry_ref",
    "expected_owner_repos",
    "missing_owner_repos",
    "unexpected_owner_repos",
    "active_receipt_total",
    "observed_owner_repo_count",
    "expected_owner_repo_count",
    "owner_repo_counts",
    "event_kind_counts",
    "owners",
    "thin_signal_flags"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_source_coverage_summary_v1"
    },
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "source_mode": {
      "type": "string",
      "enum": [
        "receipt_feed_only",
        "registry_backed_receipt_feed"
      ]
    },
    "input_registry_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "expected_owner_repos": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_owner_repos": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unexpected_owner_repos": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "active_receipt_total": {
      "type": "integer",
      "minimum": 1
    },
    "observed_owner_repo_count": {
      "type": "integer",
      "minimum": 0
    },
    "expected_owner_repo_count": {
      "type": "integer",
      "minimum": 0
    },
    "owner_repo_counts": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "event_kind_counts": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "owner_repo",
          "receipt_count",
          "share_of_total_receipts",
          "coverage_class",
          "event_kind_counts",
          "first_observed_at",
          "last_observed_at"
        ],
        "properties": {
          "owner_repo": {
            "type": "string",
            "minLength": 1
          },
          "receipt_count": {
            "type": "integer",
            "minimum": 1
          },
          "share_of_total_receipts": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "coverage_class": {
            "type": "string",
            "enum": [
              "rich",
              "active",
              "sparse"
            ]
          },
          "event_kind_counts": {
            "type": "object",
            "propertyNames": {
              "minLength": 1
            },
            "additionalProperties": {
              "type": "integer",
              "minimum": 1
            }
          },
          "first_observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_observed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "thin_signal_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
