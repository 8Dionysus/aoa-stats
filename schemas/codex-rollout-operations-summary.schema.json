{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/codex-rollout-operations-summary.schema.json",
  "title": "aoa-stats codex rollout operations summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "latest_rollout_campaign_ref",
    "latest_state",
    "active_drift_window_ref",
    "active_rollback_window_ref",
    "latest_stable_rollout_campaign_ref",
    "counts_by_state",
    "source_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_codex_rollout_operations_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "latest_rollout_campaign_ref": {
      "type": "string",
      "minLength": 1
    },
    "latest_state": {
      "enum": [
        "prepared",
        "activated",
        "monitoring",
        "stabilized",
        "rollback_open",
        "rolled_back",
        "abandoned",
        "unknown"
      ]
    },
    "active_drift_window_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "active_rollback_window_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "latest_stable_rollout_campaign_ref": {
      "type": "string",
      "minLength": 1
    },
    "counts_by_state": {
      "$ref": "#/$defs/string_count_map"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "string_count_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
