{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/automation-pipeline-summary.schema.json",
  "title": "aoa-stats automation pipeline summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "pipelines"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_automation_pipeline_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "pipelines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pipeline_ref",
          "candidate_count",
          "seed_ready_count",
          "checkpoint_required_count",
          "deterministic_ready_count",
          "reversible_ready_count",
          "next_artifact_hints",
          "evidence_ref_count",
          "latest_observed_at"
        ],
        "properties": {
          "pipeline_ref": {
            "type": "string",
            "minLength": 1
          },
          "candidate_count": {
            "type": "integer",
            "minimum": 1
          },
          "seed_ready_count": {
            "type": "integer",
            "minimum": 0
          },
          "checkpoint_required_count": {
            "type": "integer",
            "minimum": 0
          },
          "deterministic_ready_count": {
            "type": "integer",
            "minimum": 0
          },
          "reversible_ready_count": {
            "type": "integer",
            "minimum": 0
          },
          "next_artifact_hints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "evidence_ref_count": {
            "type": "integer",
            "minimum": 0
          },
          "latest_observed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

