{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/titan_summon_summary.schema.json",
  "title": "Titan summon summary",
  "type": "object",
  "required": [
    "schema_version",
    "summary_ref",
    "source_ledger_refs",
    "counts"
  ],
  "properties": {
    "schema_version": {
      "const": "titan_summon_summary/v1"
    },
    "summary_ref": {
      "const": "generated:titan-summon-summary:no-observed-ledger"
    },
    "source_ledger_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "description": "The v1 compatibility sentinel states that no owner ledger was observed; it is not a ledger instance or evidence of zero activity.",
      "items": {
        "const": "baseline:titan-summon:no-observed-ledger"
      }
    },
    "counts": {
      "type": "object",
      "required": [
        "agents_invoked",
        "reports_received",
        "findings_reported",
        "memory_candidates_created"
      ],
      "properties": {
        "agents_invoked": {
          "type": "integer",
          "minimum": 0
        },
        "reports_received": {
          "type": "integer",
          "minimum": 0
        },
        "findings_reported": {
          "type": "integer",
          "minimum": 0
        },
        "memory_candidates_created": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
