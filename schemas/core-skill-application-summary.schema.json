{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/core-skill-application-summary.schema.json",
  "title": "aoa-stats core skill application summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_core_skill_application_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kernel_id",
          "skill_name",
          "application_count",
          "latest_observed_at",
          "latest_session_ref",
          "latest_run_ref",
          "detail_event_kind_counts"
        ],
        "properties": {
          "kernel_id": {
            "type": "string",
            "minLength": 1
          },
          "skill_name": {
            "type": "string",
            "minLength": 1
          },
          "application_count": {
            "type": "integer",
            "minimum": 1
          },
          "latest_observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "latest_session_ref": {
            "type": "string",
            "minLength": 1
          },
          "latest_run_ref": {
            "type": "string",
            "minLength": 1
          },
          "detail_event_kind_counts": {
            "$ref": "#/$defs/string_count_map"
          }
        }
      }
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "string_count_map": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
