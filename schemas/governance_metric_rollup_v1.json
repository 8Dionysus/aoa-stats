{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/aoa-stats/schemas/governance_metric_rollup_v1.json",
  "title": "Governance Metric Rollup V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "created_at",
    "decision_refs",
    "evidence_refs",
    "id",
    "kind",
    "metrics",
    "notes",
    "schema_version",
    "status"
  ],
  "properties": {
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor",
        "mode"
      ],
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "reviewed"
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1,
      "const": "stats.governance_rollup"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisions",
        "open_cases"
      ],
      "properties": {
        "decisions": {
          "type": "integer",
          "minimum": 0
        },
        "open_cases": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "v1"
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "proposed"
      ]
    }
  }
}
