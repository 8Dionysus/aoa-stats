{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "live_protocol": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "owner_repo": {
      "type": "string"
    },
    "record_count": {
      "type": "integer"
    },
    "record_key": {
      "const": "prebindings"
    },
    "record_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "records": {
      "items": {
        "$ref": "./agon-stats-prebinding.schema.json"
      },
      "type": "array"
    },
    "required_stop_lines": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "runtime_effect": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "wave": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "wave",
    "owner_repo",
    "status",
    "live_protocol",
    "runtime_effect",
    "record_key",
    "record_count",
    "record_refs",
    "records",
    "required_stop_lines"
  ],
  "title": "Agon Stats Prebinding Registry",
  "type": "object"
}
