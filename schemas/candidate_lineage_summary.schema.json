{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/schemas/candidate_lineage_summary.schema.json",
  "title": "aoa-stats candidate lineage summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "stage_counts",
    "owner_target_counts",
    "owner_shape_counts",
    "status_posture_counts",
    "time_to_stage_median_days",
    "misroute_counts",
    "supersession_counts",
    "axis_pressure_counts"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_candidate_lineage_summary_v1"
    },
    "generated_from": {
      "$ref": "#/$defs/generated_from"
    },
    "stage_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed",
        "checkpointed",
        "reviewed",
        "harvested",
        "seeded",
        "planted",
        "proved",
        "promoted",
        "superseded_or_dropped"
      ],
      "properties": {
        "observed": {
          "type": "integer",
          "minimum": 0
        },
        "checkpointed": {
          "type": "integer",
          "minimum": 0
        },
        "reviewed": {
          "type": "integer",
          "minimum": 0
        },
        "harvested": {
          "type": "integer",
          "minimum": 0
        },
        "seeded": {
          "type": "integer",
          "minimum": 0
        },
        "planted": {
          "type": "integer",
          "minimum": 0
        },
        "proved": {
          "type": "integer",
          "minimum": 0
        },
        "promoted": {
          "type": "integer",
          "minimum": 0
        },
        "superseded_or_dropped": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "owner_target_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "owner_shape_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "status_posture_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "time_to_stage_median_days": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpointed",
        "reviewed",
        "harvested",
        "seeded",
        "planted",
        "proved",
        "promoted"
      ],
      "properties": {
        "checkpointed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "reviewed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "harvested": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "seeded": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "planted": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "proved": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "promoted": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "misroute_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "by_target",
        "owner_ambiguity_total"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "by_target": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "owner_ambiguity_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "supersession_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "superseded_total",
        "dropped_total"
      ],
      "properties": {
        "superseded_total": {
          "type": "integer",
          "minimum": 0
        },
        "dropped_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "axis_pressure_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  },
  "$defs": {
    "generated_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_input_paths",
        "total_receipts",
        "latest_observed_at"
      ],
      "properties": {
        "receipt_input_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "total_receipts": {
          "type": "integer",
          "minimum": 1
        },
        "latest_observed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
