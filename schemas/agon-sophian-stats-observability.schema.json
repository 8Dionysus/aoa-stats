{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assistant_contestant_allowed": {
      "const": false
    },
    "canon_write_allowed": {
      "const": false
    },
    "direct_tos_write_allowed": {
      "const": false
    },
    "forbidden_effects": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "live_protocol": {
      "const": false
    },
    "purpose": {
      "minLength": 1,
      "type": "string"
    },
    "required_evidence": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "requires_review": {
      "const": true
    },
    "review_status": {
      "const": "candidate_only"
    },
    "runtime_effect": {
      "enum": [
        "none",
        "candidate_only",
        "local_dry_run_candidate_only",
        "local_rehearsal_candidate_only"
      ]
    },
    "summary_id": {
      "minLength": 1,
      "type": "string"
    },
    "tos_canonization_allowed": {
      "const": false
    },
    "wave": {
      "const": "XVIII"
    },
    "wave_name": {
      "const": "Sophian Threshold"
    }
  },
  "required": [
    "assistant_contestant_allowed",
    "canon_write_allowed",
    "direct_tos_write_allowed",
    "forbidden_effects",
    "live_protocol",
    "purpose",
    "required_evidence",
    "requires_review",
    "review_status",
    "runtime_effect",
    "summary_id",
    "tos_canonization_allowed",
    "wave",
    "wave_name"
  ],
  "title": "agon-sophian-stats-observability.schema.json item contract",
  "type": "object"
}
