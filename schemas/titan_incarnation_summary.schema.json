{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/titan_incarnation_summary.schema.json",
  "title": "AoA Titan incarnation summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary_ref",
    "source_receipt_refs",
    "counts"
  ],
  "properties": {
    "schema_version": {
      "const": "titan_incarnation_summary/v1"
    },
    "summary_ref": {
      "const": "generated:titan-incarnation-summary:reference"
    },
    "source_receipt_refs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "description": "Compatibility field carrying the exact two aoa-agents roster example paths and one aoa-sdk session-receipt example path.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seeded_titans",
        "default_active",
        "locked_by_gate"
      ],
      "properties": {
        "seeded_titans": {
          "type": "integer",
          "minimum": 0
        },
        "default_active": {
          "type": "integer",
          "minimum": 0
        },
        "locked_by_gate": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
