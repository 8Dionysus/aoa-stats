{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/titan_incarnation_summary.schema.json",
  "title": "AoA Titan incarnation summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "summary_ref",
    "source_receipt_refs",
    "counts"
  ],
  "properties": {
    "schema_version": {
      "const": "titan_incarnation_summary/v1"
    },
    "summary_ref": {
      "type": "string"
    },
    "source_receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
