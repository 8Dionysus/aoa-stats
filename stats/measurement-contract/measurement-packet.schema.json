{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/stats/measurement-contract/measurement-packet.schema.json",
  "title": "OS Abyss evidence-linked measurement packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_ref",
    "contract_version",
    "measurement_id",
    "writer_repo",
    "observation_id",
    "observed_at",
    "object_ref",
    "population",
    "sample",
    "cohort",
    "window",
    "dimensions",
    "value",
    "uncertainty",
    "provenance",
    "reporting_rule",
    "posture",
    "progress"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_stats_measurement_packet_v1"
    },
    "contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "measurement_id": {
      "type": "string",
      "minLength": 1
    },
    "writer_repo": {
      "type": "string",
      "minLength": 1
    },
    "observation_id": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "object_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "definition_ref",
        "size"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "definition_ref": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size",
        "selection"
      ],
      "properties": {
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "selection": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cohort": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "start",
        "end",
        "temporality"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "temporality": {
          "enum": [
            "instant",
            "interval",
            "cumulative"
          ]
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "integer",
          "boolean"
        ]
      }
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "kind",
        "unit"
      ],
      "properties": {
        "status": {
          "enum": [
            "observed",
            "missing",
            "unknown",
            "stale"
          ]
        },
        "kind": {
          "enum": [
            "count",
            "gauge",
            "rate",
            "ratio",
            "distribution",
            "quantile",
            "pass_at_k",
            "pass_all_k"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "number": {
          "type": "number"
        },
        "numerator": {
          "type": "number"
        },
        "denominator": {
          "type": "number"
        },
        "distribution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "count",
            "minimum",
            "maximum",
            "quantiles"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1
            },
            "minimum": {
              "type": "number"
            },
            "maximum": {
              "type": "number"
            },
            "quantiles": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "q",
                  "value"
                ],
                "properties": {
                  "q": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "value": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "quantile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "q",
            "value"
          ],
          "properties": {
            "q": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "value": {
              "type": "number"
            }
          }
        },
        "k": {
          "type": "integer",
          "minimum": 1
        },
        "successes": {
          "type": "integer",
          "minimum": 0
        },
        "attempts": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "sample_size",
        "method"
      ],
      "properties": {
        "status": {
          "enum": [
            "estimated",
            "not_estimated",
            "not_applicable"
          ]
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "lower": {
          "type": "number"
        },
        "upper": {
          "type": "number"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_refs",
        "derivation_ref",
        "source_revision"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "ref"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "derivation_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_revision": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "reporting_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshness",
        "live_state",
        "privacy",
        "raw_content_included"
      ],
      "properties": {
        "freshness": {
          "enum": [
            "current",
            "stale",
            "unknown"
          ]
        },
        "live_state": {
          "enum": [
            "live",
            "reference"
          ]
        },
        "privacy": {
          "enum": [
            "public",
            "internal",
            "sensitive"
          ]
        },
        "raw_content_included": {
          "const": false
        }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "completed",
        "total"
      ],
      "properties": {
        "state": {
          "enum": [
            "partial",
            "terminal"
          ]
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    }
  }
}
