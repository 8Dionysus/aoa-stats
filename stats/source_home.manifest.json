{
  "schema_version": "aoa_stats_source_home_v2",
  "owner_repo": "aoa-stats",
  "home": "stats/",
  "status": "active_source_home",
  "role": "Source-authored home for receipt admission, derived read-model profiles, part-local operation contracts, catalog posture, authority ceilings, and mechanics handoffs.",
  "home_rules": [
    "stats/ owns authored intake and read-model meaning, not Python implementation.",
    "Every active public catalog surface has one authored profile under stats/read-models/active/.",
    "Contract-only surface candidates live under stats/read-models/deferred/.",
    "Canonical published schemas remain under schemas/.",
    "Committed derived outputs remain under generated/.",
    "Repeatable operation payloads and validation remain under mechanics/.",
    "Part-local observation contracts without public catalog surfaces have one authored meaning record under stats/operation-contracts/ and cross back to their mechanic owner.",
    "The repo-local MCP remains a read-only derived access route.",
    "No generated catalog or owner payload is copied under stats/."
  ],
  "branches": [
    {
      "id": "intake_contract",
      "path": "stats/intake-contract",
      "role": "Shared receipt-envelope and event-family admission meaning for deterministic stats derivation.",
      "families": [
        "intake_contract"
      ],
      "owner_surface": "stats/intake-contract/AGENTS.md",
      "authority_ceiling": "Owns the shared stats envelope and event-kind admission vocabulary only; source repositories retain payload schemas, payload meaning, verdicts, workflow state, and domain truth."
    },
    {
      "id": "read_models",
      "path": "stats/read-models",
      "role": "Authored source profiles for active and deferred derived read models.",
      "families": [
        "read_models"
      ],
      "owner_surface": "stats/read-models/AGENTS.md",
      "authority_ceiling": "Owns derived questions, profile vocabulary, schema/output routes, and stats authority ceilings; stronger owners retain every input fact and verdict."
    },
    {
      "id": "operation_contracts",
      "path": "stats/operation-contracts",
      "role": "One authored stats question, evidence posture, authority ceiling, and owner-return route per active part-local observation contract that does not publish a public catalog read model.",
      "families": [
        "operation_contracts"
      ],
      "owner_surface": "stats/operation-contracts/AGENTS.md",
      "authority_ceiling": "Owns the stats meaning and authority ceiling of the operation family only; mechanic parts own payload and execution while stronger owners retain source truth."
    },
    {
      "id": "surface_catalog",
      "path": "stats/surface-catalog",
      "role": "Public catalog and read-only consumer-access posture over authored read-model profiles.",
      "families": [
        "surface_catalog"
      ],
      "owner_surface": "stats/surface-catalog/AGENTS.md",
      "authority_ceiling": "Owns the deterministic catalog contract and consumer caution posture only; generated entries remain weaker than their owner-local inputs and linked evidence."
    }
