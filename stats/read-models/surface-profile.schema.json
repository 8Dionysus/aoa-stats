{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-stats/stats/read-models/surface-profile.schema.json",
  "title": "aoa-stats authored surface profile",
  "oneOf": [
    {
      "$ref": "#/$defs/activeProfile"
    },
    {
      "$ref": "#/$defs/deferredProfile"
    },
    {
      "$ref": "#/$defs/retiredProfile"
    }
  ],
  "$defs": {
    "mechanicRoutes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^mechanics/[a-z0-9-]+/parts/[a-z0-9-]+$"
      }
    },
    "activeProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "catalog_order",
        "lifecycle",
        "name",
        "surface_ref",
        "schema_ref",
        "primary_question",
        "derivation_rule",
        "input_posture",
        "owner_truth_inputs",
        "authority_ceiling",
        "consumer_risk",
        "live_state_capable",
        "mechanic_routes"
      ],
      "properties": {
        "schema_version": {
          "const": "aoa_stats_surface_profile_source_v1"
        },
        "catalog_order": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle": {
          "const": "active"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "surface_ref": {
          "type": "string",
          "pattern": "^generated/[a-z0-9_]+\\.min\\.json$"
        },
        "schema_ref": {
          "type": "string",
          "pattern": "^schemas/[A-Za-z0-9_.-]+\\.json$"
        },
        "primary_question": {
          "type": "string",
          "minLength": 1
        },
        "derivation_rule": {
          "type": "string",
          "minLength": 1
        },
        "input_posture": {
          "type": "string",
          "minLength": 1
        },
        "owner_truth_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority_ceiling": {
          "type": "string",
          "minLength": 1
        },
        "consumer_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "live_state_capable": {
          "type": "boolean",
          "description": "Whether local live refresh may materialize and advertise this surface from its current source contract."
        },
        "mechanic_routes": {
          "$ref": "#/$defs/mechanicRoutes"
        }
      }
    },
    "deferredProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "lifecycle",
        "name",
        "status",
        "contract_ref",
        "schema_ref",
        "input_posture",
        "owner_truth_inputs",
        "activation_condition",
        "activation_gaps",
        "authority_ceiling",
        "consumer_risk",
        "mechanic_routes"
      ],
      "properties": {
        "schema_version": {
          "const": "aoa_stats_surface_profile_source_v1"
        },
        "lifecycle": {
          "const": "deferred"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "status": {
          "const": "contract_only"
        },
        "contract_ref": {
          "type": "string",
          "minLength": 1
        },
        "schema_ref": {
          "type": "string",
          "pattern": "^(schemas|mechanics/[a-z0-9-]+/parts/[a-z0-9-]+/schemas)/[A-Za-z0-9_.-]+\\.json$"
        },
        "input_posture": {
          "type": "string",
          "minLength": 1
        },
        "owner_truth_inputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "activation_condition": {
          "type": "string",
          "minLength": 1
        },
        "activation_gaps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority_ceiling": {
          "type": "string",
          "minLength": 1
        },
        "consumer_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "mechanic_routes": {
          "$ref": "#/$defs/mechanicRoutes"
        }
      }
    },
    "retiredProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "lifecycle",
        "name",
        "former_catalog_order",
        "retired_surface_ref",
        "schema_ref",
        "retired_on",
        "retirement_reason",
        "replacement_ref",
        "cleanup_scopes",
        "consumer_return_routes",
        "decision_ref",
        "former_mechanic_routes"
      ],
      "properties": {
        "schema_version": {
          "const": "aoa_stats_surface_profile_source_v1"
        },
        "lifecycle": {
          "const": "retired"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "former_catalog_order": {
          "type": "integer",
          "minimum": 1,
          "description": "Stable catalog slot formerly held by this retired surface; active profiles may not reuse it."
        },
        "retired_surface_ref": {
          "type": "string",
          "pattern": "^generated/[a-z0-9_]+\\.min\\.json$"
        },
        "schema_ref": {
          "type": "string",
          "pattern": "^schemas/[A-Za-z0-9_.-]+\\.json$"
        },
        "retired_on": {
          "type": "string",
          "format": "date"
        },
        "retirement_reason": {
          "type": "string",
          "minLength": 1
        },
        "replacement_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "cleanup_scopes": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "committed_output",
              "summary_surface_catalog",
              "managed_live_state",
              "consumer_hints"
            ]
          }
        },
        "consumer_return_routes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9-]+/.+$"
          }
        },
        "decision_ref": {
          "type": "string",
          "pattern": "^docs/decisions/AOST-D-[0-9]{4}-[a-z0-9-]+\\.md$"
        },
        "former_mechanic_routes": {
          "$ref": "#/$defs/mechanicRoutes"
        }
      }
    }
  }
}
