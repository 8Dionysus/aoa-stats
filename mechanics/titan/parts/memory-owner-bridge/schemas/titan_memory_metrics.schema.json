{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Memory Metrics",
  "type": "object",
  "required": [
    "version",
    "metrics",
    "authority"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "metrics": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "authority": {
      "type": "string"
    }
  }
}
