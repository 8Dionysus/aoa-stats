{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/micro_friction_receipt.schema.json",
  "title": "AoA micro friction receipt",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_ref",
    "owner_repo",
    "observed_at",
    "friction_kind",
    "friction_note",
    "requested_next_step",
    "source_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_micro_friction_receipt_v1"
    },
    "receipt_ref": {
      "type": "string",
      "minLength": 3
    },
    "owner_repo": {
      "type": "string",
      "minLength": 3
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "friction_kind": {
      "type": "string",
      "minLength": 3
    },
    "friction_note": {
      "type": "string",
      "minLength": 5
    },
    "requested_next_step": {
      "type": "string",
      "minLength": 3
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "boundary_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
