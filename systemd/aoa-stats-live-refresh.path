[Unit]
Description=Watch owner-local live receipt logs for aoa-stats refresh

[Path]
PathModified=/srv/aoa-skills/.aoa/live_receipts/session-harvest-family.jsonl
PathModified=/srv/aoa-evals/.aoa/live_receipts/eval-result-receipts.jsonl
Unit=aoa-stats-live-refresh.service

[Install]
WantedBy=default.target
