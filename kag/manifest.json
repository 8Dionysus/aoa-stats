{
  "schema_version": "aoa-local-kag-manifest-v1",
  "repo": "aoa-stats",
  "owner_surface": "kag/AGENTS.md",
  "source_surfaces": [
    {
      "repo": "aoa-stats",
      "path": "stats/source_home.manifest.json",
      "source_class": "stats_source",
      "role": "primary",
      "authority": "authored_source"
    },
    {
      "repo": "aoa-stats",
      "path": "stats/read-models/README.md",
      "source_class": "stats_source",
      "role": "supporting",
      "authority": "authored_source"
    },
    {
      "repo": "aoa-stats",
      "path": "generated/summary_surface_catalog.min.json",
      "source_class": "stats_source",
      "role": "supporting",
      "authority": "derived_readmodel"
    },
    {
      "repo": "aoa-stats",
      "path": "generated/agon_kag_stats_observability_registry.min.json",
      "source_class": "stats_source",
      "role": "supporting",
      "authority": "derived_readmodel"
    },
    {
      "repo": "aoa-stats",
      "path": "stats/README.md",
      "source_class": "stats_source",
      "role": "owner_route",
      "authority": "authored_source"
    },
    {
      "repo": "aoa-stats",
      "path": "README.md",
      "source_class": "stats_source",
      "role": "owner_route",
      "authority": "authored_source"
    }
  ],
  "record_classes": [
    "node",
    "edge",
    "index",
    "projection",
    "receipt"
  ],
  "storage_posture": {
    "git_surface": "portable_records",
    "payload_class": "manifest",
    "runtime_route": "source-repo"
  },
  "validation_routes": [
    {
      "route": "python scripts/validate_stats_source_home.py",
      "lane": "owner-local"
    },
    {
      "route": "python mechanics/agon/parts/kag-observability/scripts/build_agon_kag_stats_observability_registry.py --check",
      "lane": "owner-local"
    },
    {
      "route": "python mechanics/agon/parts/kag-observability/scripts/validate_agon_kag_stats_observability_registry.py",
      "lane": "owner-local"
    },
    {
      "route": "python scripts/build_views.py --check",
      "lane": "owner-local"
    },
    {
      "route": "python scripts/validate_repo.py",
      "lane": "owner-local"
    }
  ],
  "consumer_routes": [
    "aoa-kag registry",
    "abyss-stack federation mirror",
    "aoa-kag-mcp resource"
  ],
  "owner_return_routes": [
    {
      "repo": "aoa-stats",
      "surface": "stats/README.md",
      "route_kind": "authored_meaning"
    },
    {
      "repo": "aoa-stats",
      "surface": "README.md",
      "route_kind": "routing"
    }
  ]
}
